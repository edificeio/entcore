{
  "name": "auth",
  "version": "0.0.0",
  "private": true,
  "license": "GPL-3.0",
  "author": "Edifice",
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist node_modules pnpm-lock.yaml",
    "build": "vite build",
    "dev": "vite",
    "format": "prettier --write .",
    "lint": "eslint .",
    "pre-commit": "lint-staged",
    "pre-push": "pnpm run typecheck && pnpm run test",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "typecheck": "tsc -b --noEmit --pretty"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "pnpm run format",
      "pnpm run lint"
    ]
  },
  "dependencies": {
    "@edifice.io/bootstrap": "develop-enabling",
    "@edifice.io/client": "develop-enabling",
    "@edifice.io/react": "develop-enabling",
    "@react-spring/web": "9.7.5",
    "@tanstack/react-query": "5.90.21",
    "@uidotdev/usehooks": "2.4.1",
    "clsx": "2.1.1",
    "dompurify": "^3.4.1",
    "i18next": "23.8.1",
    "i18next-http-backend": "2.4.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-error-boundary": "4.0.13",
    "react-hook-form": "7.71.2",
    "react-i18next": "14.1.0",
    "react-router-dom": "6.30.2",
    "zustand": "4.5.7"
  },
  "devDependencies": {
    "@axe-core/react": "4.11.1",
    "@eslint/js": "9.39.1",
    "@tanstack/react-query-devtools": "5.91.3",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/node": "18.19.55",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.2",
    "@vitest/coverage-v8": "2.1.3",
    "@vitest/ui": "2.1.3",
    "eslint": "9.16.0",
    "eslint-plugin-react-hooks": "5.1.0-rc.0",
    "eslint-plugin-react-refresh": "0.4.12",
    "globals": "15.11.0",
    "husky": "9.1.7",
    "jsdom": "25.0.1",
    "lint-staged": "15.2.9",
    "msw": "2.12.10",
    "nx": "19.6.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vite": "5.4.6",
    "vite-tsconfig-paths": "5.0.1",
    "vitest": "2.1.3"
  },
  "packageManager": "pnpm@9.12.2",
  "engines": {
    "node": ">= 20"
  },
  "nx": {}
}
